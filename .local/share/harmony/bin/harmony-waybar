#!/bin/bash
source harmony-color-codes

case "$1" in
    "")
        exit 1
    ;;
    "dock")
        if [ "$2" = "toggle" ]; then
            killall -SIGUSR1 nwg-dock-hyprland
        else
            killall nwg-dock-hyprland
            nwg-dock-hyprland -mb 5 -mt 0 -i 30 -x -r -nolauncher & disown
        fi
    ;;
    "kde")
        killall -9 nwg-dock-hyprland > /dev/null 2>&1
        killall -9 waybar > /dev/null 2>&1
        waybar -c ~/.config/waybar/styles/kde/config.jsonc -s ~/.config/waybar/styles/kde/style.css -b 1 & disown
    ;;
    "mint")
        killall -9 nwg-dock-hyprland > /dev/null 2>&1
        killall -9 waybar > /dev/null 2>&1
        waybar -c ~/.config/waybar/styles/cinnamon/config.jsonc -s ~/.config/waybar/styles/cinnamon/style.css -b 1 & disown
    ;;
    "end4")
        killall -9 waybar > /dev/null 2>&1
        waybar -c ~/.config/waybar/styles/end_4/config.jsonc -s ~/.config/waybar/styles/end_4/style.css -b 1 & disown
        # sleep .5 && harmony-reload "dock"
    ;;
    "waybar")
        if [ "$2" = "rl" ]; then
            killall -USR2 waybar > /dev/null 2>&1
        elif [ "$2" = "toggle" ]; then
            killall -USR1 waybar > /dev/null 2>&1
        else
            killall -9 waybar > /dev/null 2>&1
            waybar > /dev/null 2>&1 & disown
        fi
    ;;
    *)
        exit 1
    ;;
esac

echo "ok"
exit 0
