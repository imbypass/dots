// Zed settings
{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "icon_theme": "JetBrains New UI Icons (Dark)",
  "show_completions_on_input": false,
  "language_servers": ["!eslint"],
  "base_keymap": "VSCode",
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4"
    }
  },
  "format_on_save": "off",
  "vim_mode": false,
  "theme": "Omarchy",
  "ui_font_size": 14.5,
  "ui_font_weight": 600.0,
  "ui_font_family": "GeistMono Nerd Font Mono",
  "buffer_font_size": 12.5,
  "buffer_font_weight": 400.0,
  "buffer_font_family": "GeistMono Nerd Font Mono",
  "buffer_line_height": {
    "custom": 1.525
  },
  "terminal": {
    "shell": {
      "program": "/usr/bin/fish"
    }
  }
}
